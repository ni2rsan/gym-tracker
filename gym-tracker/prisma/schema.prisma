generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js v5 required tables ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application tables ────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String?
  username           String?   @unique
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  profileImageBase64 String?   @db.Text
  heightCm           Int?
  role               String    @default("USER")  // "USER" | "ADMIN"
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  workoutSessions       WorkoutSession[]
  bodyMetrics           BodyMetricEntry[]
  customExercises       Exercise[]           @relation("UserCustomExercises")
  exerciseSettings      UserExerciseSetting[]
  withingsConnection    WithingsConnection?
  plannedWorkouts       PlannedWorkout[]
  plannedWorkoutSeries  PlannedWorkoutSeries[]
  sorryTokens           UserSorryToken[]
  requests              UserRequest[]

  sentFriendRequests     Friendship[]           @relation("FriendshipSender")
  receivedFriendRequests Friendship[]           @relation("FriendshipReceiver")
  privacySettings        UserPrivacySettings?
  friendPrivacyOverrides FriendPrivacyOverride[] @relation("PrivacyOverrideOwner")
  friendOverridesAboutMe FriendPrivacyOverride[] @relation("PrivacyOverrideFriend")
  fistBumps              WorkoutFistBump[]
  socialNotificationSeen SocialNotificationSeen?
  friendInvite           FriendInvite?
}

enum MuscleGroup {
  UPPER_BODY
  LOWER_BODY
  BODYWEIGHT
  CARDIO
}

model Exercise {
  id              String      @id @default(cuid())
  name            String
  muscleGroup     MuscleGroup
  isDefault       Boolean     @default(false)
  isBodyweight    Boolean     @default(false)
  isCompound      Boolean     @default(false)
  sortOrder       Int         @default(0)
  createdByUserId String?

  createdBy    User?                 @relation("UserCustomExercises", fields: [createdByUserId], references: [id], onDelete: SetNull)
  sets         ExerciseSet[]
  userSettings UserExerciseSetting[]

  @@index([muscleGroup])
  @@index([createdByUserId])
}

model UserExerciseSetting {
  id            String  @id @default(cuid())
  userId        String
  exerciseId    String
  isPinned      Boolean @default(false)
  sortOrder     Int     @default(0)
  isHidden      Boolean @default(false)
  preferredSets Int?    // null = use default (3 for weighted, 1 for bodyweight/cardio)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
}

model WorkoutSession {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets      ExerciseSet[]
  fistBumps WorkoutFistBump[]

  @@index([userId, date])
}

// APPEND-ONLY: Never UPDATE or DELETE rows. Always INSERT new records.
model ExerciseSet {
  id         String   @id @default(cuid())
  sessionId  String
  exerciseId String
  setNumber  Int
  reps       Int
  weightKg   Decimal? @db.Decimal(6, 2)
  recordedAt DateTime @default(now())

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
  @@index([recordedAt])
}

// APPEND-ONLY: Never UPDATE or DELETE rows. Pencil icon creates a NEW row.
model BodyMetricEntry {
  id                   String   @id @default(cuid())
  userId               String
  weightKg             Decimal? @db.Decimal(5, 2)
  bodyFatPct           Decimal? @db.Decimal(4, 2)
  fatMassKg            Decimal? @db.Decimal(5, 2)  // Withings type 5
  muscleMassKg         Decimal? @db.Decimal(5, 2)  // Withings type 76
  recordedAt           DateTime @default(now())
  notes                String?
  source               String?  // "manual" | "withings" — null = legacy manual entry
  withingsMeasureGrpId BigInt?  // Withings grpid for deduplication on re-sync

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

// ─── Workout Planner ───────────────────────────────────────────────────────

enum BlockType {
  UPPER_BODY
  LOWER_BODY
  BODYWEIGHT
  FULL_BODY
  CARDIO
}

enum SeriesRuleType {
  WEEKDAYS
  INTERVAL
}

model PlannedWorkoutSeries {
  id              String         @id @default(cuid())
  userId          String
  blockType       BlockType
  ruleType        SeriesRuleType
  weekdays        Int[]
  intervalDays    Int?
  startDate       DateTime       @db.Date
  streakResetDate DateTime?      @db.Date
  createdAt       DateTime       @default(now())

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workouts PlannedWorkout[]

  @@index([userId])
}

model PlannedWorkout {
  id           String    @id @default(cuid())
  userId       String
  date         DateTime  @db.Date
  blockType    BlockType
  seriesId     String?
  sorryExcused Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  series PlannedWorkoutSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

model UserSorryToken {
  id        String @id @default(cuid())
  userId    String
  month     String // "YYYY-MM"
  usedCount Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
}

// ─── Bug Reports & Feature Requests ───────────────────────────────────────

enum RequestType {
  BUG
  FEATURE
}

enum RequestStatus {
  IN_REVIEW
  ACCEPTED
  DECLINED
  DEPLOYED
}

model UserRequest {
  id               String        @id @default(cuid())
  userId           String
  type             RequestType
  status           RequestStatus @default(IN_REVIEW)
  text             String        @db.Text
  screenshotBase64 String?       @db.Text
  adminNote        String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ─── Social ────────────────────────────────────────────────────────────────

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model WorkoutFistBump {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId],    references: [id], onDelete: Cascade)
  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@index([userId])
}

model SocialNotificationSeen {
  id                String   @id @default(cuid())
  userId            String   @unique
  lastSeenRequests  DateTime @default(now())
  lastSeenFeed      DateTime @default(now())
  lastSeenFistBumps DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  sender   User @relation("FriendshipSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model UserPrivacySettings {
  id           String  @id @default(cuid())
  userId       String  @unique
  shareWeight  Boolean @default(true)
  shareBodyFat Boolean @default(true)
  sharePRs     Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FriendPrivacyOverride {
  id           String   @id @default(cuid())
  userId       String
  friendId     String
  shareWeight  Boolean?
  shareBodyFat Boolean?
  sharePRs     Boolean?

  user   User @relation("PrivacyOverrideOwner",  fields: [userId],   references: [id], onDelete: Cascade)
  friend User @relation("PrivacyOverrideFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
}

model FriendInvite {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ─── Withings integration ──────────────────────────────────────────────────

model WithingsConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  expiresAt    DateTime
  isActive     Boolean   @default(true)
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
